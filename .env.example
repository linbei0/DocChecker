# DocChecker runtime configuration
#
# Copy this file to `.env` in the repository root and fill in real values.
# Do not commit `.env`; it may contain secrets.

# Rule extraction mode:
# - local: deterministic local parser only, no LLM call.
# - hybrid: local DOCX structure parser + OpenAI-compatible LLM rule candidate extraction.
DOC_CHECKER_RULE_EXTRACTOR_MODE=local

# Required only when DOC_CHECKER_RULE_EXTRACTOR_MODE=hybrid.
# The endpoint must be OpenAI-compatible and should NOT include `/chat/completions`.
DOC_CHECKER_LLM_API_BASE=https://api.openai.com/v1
DOC_CHECKER_LLM_API_KEY=replace_with_your_api_key
DOC_CHECKER_LLM_MODEL=gpt-4.1-mini

# Optional defaults.
DOC_CHECKER_STORAGE_DIR=storage
DOC_CHECKER_TASK_EXECUTION_MODE=inline
